# NEMESIS — LLM provider keys (template)
#
# Copy this file to `.env` and fill in the keys you have. NEMESIS loads `.env`
# automatically at startup (see nemesis/config.py::load_dotenv_file) — no
# `export` needed. A real shell env var of the same name takes precedence.
#
# NVIDIA NIM (build.nvidia.com) is the PRIMARY backend — get a key there first.
# The provider chain falls back in order; you only need ONE to start:
#   NVIDIA gpt-oss-120b -> NVIDIA qwen3.5-397b -> NVIDIA mistral-small-4
#   -> Cerebras -> Groq -> Gemini

NVIDIA_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
GOOGLE_AI_KEY=
